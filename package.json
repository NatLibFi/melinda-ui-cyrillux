{
  "name": "melinda-ui-cyrillux",
  "version": "2.0.8-alpha.1",
  "description": "UI for Melinda Cyrillux application",
  "author": "The National Library of Finland",
  "license": "MIT",
  "keywords": [
    "cyrillux",
    "melinda",
    "natlibfi"
  ],
  "homepage": "https://github.com/NatLibFi/melinda-ui-cyrillux#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NatLibFi/melinda-ui-cyrillux.git"
  },
  "bugs": {
    "url": "https://github.com/NatLibFi/melinda-ui-cyrillux/issues"
  },
  "main": "src/index.js",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "oldest-build": "babel src --out-dir=dist --delete-dir-on-start --copy-files",
    "old-build": "esbuild \"src/**/*.js\" --sourcemap --platform=node --outdir=dist",
    "build": "node build.js",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "test": "npm run lint && npm run test:base",
    "dev:test": "cross-env DEBUG=@natlibfi/* NODE_ENV=test node --watch --test --experimental-test-coverage --test-reporter=spec './src/*.test.mjs' './src/**/*.test.mjs'",
    "old-test:base": "cross-env NODE_ENV=test nyc mocha",
    "test:base": "node --test --test-force-exit --experimental-test-coverage --test-reporter=spec './tests/*.test.mjs' './tests/**/*.test.mjs'"
  },
  "dependencies": {
    "@natlibfi/marc-record": "^10.0.1",
    "@natlibfi/marc-record-serializers": "^11.0.1",
    "@natlibfi/marc-record-validate": "^9.0.0",
    "@natlibfi/marc-record-validators-melinda": "^12.0.11",
    "@natlibfi/melinda-backend-commons": "^3.0.5",
    "@natlibfi/melinda-commons": "^14.0.2",
    "@natlibfi/melinda-rest-api-client": "^6.0.3",
    "@natlibfi/melinda-ui-commons": "^6.0.0",
    "@natlibfi/passport-melinda-aleph": "^4.0.0",
    "@natlibfi/passport-melinda-jwt": "^3.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "debug": "^4.4.3",
    "express": "^5.2.1",
    "express-handlebars": "^8.0.7",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "uuid": "^13.0.0",
    "xregexp": "^5.1.2"
  },
  "devDependencies": {
    "@natlibfi/fixugen": "^3.0.1",
    "@natlibfi/fixura": "^4.0.1",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0"
  }
}
